<Window x:Class="QMan.App.DrUploadReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="문서 업로드 안내"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        MaxWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BrushBg}"
        Foreground="{StaticResource BrushText}"
        FontFamily="Segoe UI">
    <StackPanel Margin="20,18,20,16">
        <TextBlock TextWrapping="Wrap" FontSize="14" LineHeight="22" Margin="0,0,0,16"
                   Text="문서보안(DRM) 파일은 업로드 할 수 없습니다. 반드시 문서보안 해제후 업로드 해주세요."/>

        <CheckBox x:Name="DoNotShowAgainCheck" Content="다시보지않기" FontSize="13"
                  Margin="0,0,0,18" VerticalContentAlignment="Center"/>

        <Button Content="확인" MinWidth="100" Height="36" HorizontalAlignment="Right"
                Style="{StaticResource AccentButton}" IsDefault="True" Click="Ok_OnClick"/>
    </StackPanel>
</Window>
