<?xml version="1.0" encoding="utf-8"?>
<!--
  오프라인·포터블 배포 (win-x64).

  폴더 정리:
  - 관리 DLL 대부분은 QMan.exe 단일 파일에 묶임 (PublishSingleFile).
  - 루트에는 QMan.exe, 안내 txt, runtimeconfig 등 소수 파일(실행 폴더에 native 없음).

  실행: 압축 해제 폴더의 QMan.exe

  sqlite-vec: 빌드 전 QMan.App\native\ 에 DLL → exe에 임베드, 실행 시 %LocalAppData%\QMan\vec\ 로 풀림.

  명령줄:
    dotnet publish QMan.App\QMan.App.csproj -p:PublishProfile=Portable-win-x64
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- 단일 파일 번들과 R2R 조합은 환경에 따라 충돌할 수 있어 끔 -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <CopyOutputSymbolsToPublishDirectory>false</CopyOutputSymbolsToPublishDirectory>
    <PublishDir>..\dist\QMan-portable-win-x64\</PublishDir>
    <!-- 불필요한 위성(다국어) 리소스 폴더 생성 최소화 -->
    <SatelliteResourceLanguages>ko</SatelliteResourceLanguages>
  </PropertyGroup>

  <!-- single-file publish 후 남는 빈 폴더·참조 PDB 제거 -->
  <Target Name="QManPortablePostClean" AfterTargets="Publish">
    <ItemGroup>
      <_PublishPdb Include="$(PublishDir)*.pdb" />
    </ItemGroup>
    <Delete Files="@(_PublishPdb)" TreatErrorsAsWarnings="true" />
    <Exec
      Condition="'$(OS)' == 'Windows_NT'"
      Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;if (Test-Path -LiteralPath '$(PublishDir)') { Get-ChildItem -LiteralPath '$(PublishDir)' -Directory -ErrorAction SilentlyContinue | Where-Object { -not (Get-ChildItem $_.FullName -Recurse -File -ErrorAction SilentlyContinue | Select-Object -First 1) } | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue }&quot;" />
  </Target>
</Project>
