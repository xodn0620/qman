<Window x:Class="QMan.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Height="520" Width="540"
        MinWidth="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrushBg}"
        Foreground="{StaticResource BrushText}"
        FontFamily="Segoe UI"
        Closing="SettingsWindow_OnClosing">
    <Grid Margin="22,18,22,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="FirstRunNotice" Grid.Row="0" TextWrapping="Wrap" FontSize="13" LineHeight="20"
                   Foreground="{StaticResource BrushAccentDeep}" Margin="0,0,0,14"
                   Text="처음 실행입니다. LLM 설정을 입력한 뒤 「저장」을 눌러 주세요."
                   Visibility="Collapsed"/>

        <TextBlock Grid.Row="1" Text="제공자" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
        <ComboBox x:Name="ProviderCombo" Grid.Row="2" FontSize="14" Padding="8,6" Margin="0,0,0,14"
                  SelectionChanged="ProviderCombo_OnSelectionChanged">
            <ComboBoxItem Content="OpenAI" Tag="openai"/>
            <ComboBoxItem Content="Ollama" Tag="ollama"/>
            <ComboBoxItem Content="Claude" Tag="claude"/>
            <ComboBoxItem Content="Google AI" Tag="googleai"/>
            <ComboBoxItem Content="DS Playground" Tag="alibabacloud"/>
        </ComboBox>

        <TextBlock x:Name="LlmModelCaption" Grid.Row="3" Text="LLM 모델" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
        <TextBox x:Name="ChatModelBox" Grid.Row="4" FontSize="14" Padding="8,6" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="5" Text="임베딩 모델" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
        <TextBox x:Name="EmbeddingModelBox" Grid.Row="6" FontSize="14" Padding="8,6" Margin="0,0,0,12"/>

        <StackPanel x:Name="PanelApiKey" Grid.Row="7" Margin="0,0,0,12">
            <TextBlock Text="API 키" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
            <TextBox x:Name="ApiKeyBox" FontSize="14" Padding="8,6" TextWrapping="NoWrap"/>
        </StackPanel>

        <StackPanel x:Name="PanelEmbeddingApiKey" Grid.Row="8" Margin="0,0,0,12" Visibility="Collapsed">
            <TextBlock Text="임베딩 API 키 (OpenAI)" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
            <TextBlock Text="Claude는 채팅만 Anthropic입니다. 임베딩은 OpenAI 키가 필요합니다."
                       FontSize="11" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBox x:Name="EmbeddingApiKeyBox" FontSize="14" Padding="8,6"/>
        </StackPanel>

        <StackPanel x:Name="PanelUrl" Grid.Row="9" VerticalAlignment="Top" Margin="0,8,0,0">
            <TextBlock Text="API URL (비우면 기본값)" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
            <TextBox x:Name="UrlBox" FontSize="14" Padding="8,6" Margin="0,0,0,8"/>
        </StackPanel>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button x:Name="CancelButton" Content="취소" MinWidth="96" Height="38" Margin="0,0,10,0" Click="Cancel_OnClick"/>
            <Button Content="저장" MinWidth="96" Height="38" Style="{StaticResource AccentButton}" Click="Save_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
