<Window x:Class="QMan.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Icon="/Assets/app.ico"
        MinHeight="420" Height="600" Width="540"
        MinWidth="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrushBg}"
        Foreground="{StaticResource BrushText}"
        FontFamily="Segoe UI"
        >
    <Grid Margin="22,12,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0"
                      CanContentScroll="False">
            <StackPanel>
                <TextBlock Grid.Row="0" Text="LLM 백엔드" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
                <ComboBox x:Name="ModeCombo" FontSize="14" Padding="8,6" Margin="0,0,0,14"
                          SelectionChanged="ModeCombo_OnSelectionChanged">
                    <ComboBoxItem Content="타사 AI" Tag="third"/>
                    <ComboBoxItem Content="DS Playground" IsSelected="True" Tag="ds"/>
                </ComboBox>

                <TextBlock x:Name="FirstRunNotice" TextWrapping="Wrap" FontSize="13" LineHeight="20"
                           Foreground="{StaticResource BrushAccentDeep}" Margin="0,0,0,14"
                           Text="처음 실행입니다. LLM·임베딩 모델을 입력한 뒤 하단「저장」을 눌러 주세요. (DS Playground: LLM·임베딩 API 키가 다를 수 있습니다. 타사 AI: URL/키에 따라 엔드포인트를 추론합니다.)"
                           Visibility="Collapsed"/>

                <TextBlock x:Name="LlmModelLabel" Text="LLM 모델" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
                <TextBox x:Name="ChatModelBox" FontSize="14" Padding="8,6" Margin="0,0,0,12"
                         TextChanged="FormInferenceFields_OnTextChanged"/>

                <TextBlock x:Name="EmbModelLabel" Text="임베딩 모델" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
                <TextBox x:Name="EmbeddingModelBox" FontSize="14" Padding="8,6" Margin="0,0,0,12"
                         TextChanged="FormInferenceFields_OnTextChanged"/>

                <StackPanel x:Name="PanelApiKey" Margin="0,0,0,12">
                    <TextBlock x:Name="ApiKeyLabel" Text="LLM API 키 (선택 — 비우면 환경 변수 또는 로컬 백엔드)" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="ApiKeyBox" FontSize="14" Padding="8,6"
                                 PasswordChanged="SecretFields_OnPasswordChanged"/>
                </StackPanel>

                <StackPanel x:Name="PanelEmbeddingApiKey" Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock x:Name="EmbeddingKeyTitle" Text="임베딩 API 키" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="EmbeddingKeyHint" Text="DS Playground: 임베딩 API용 키(채팅용과 다를 수 있음)."
                               FontSize="11" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" Margin="0,0,0,6"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="ClaudeEmbeddingKeyHint" Text="Anthropic으로 채팅할 때 임베딩은 OpenAI 호환 키가 필요합니다."
                               FontSize="11" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" Margin="0,0,0,6"
                               Visibility="Collapsed"/>
                    <PasswordBox x:Name="EmbeddingApiKeyBox" FontSize="14" Padding="8,6"
                                 PasswordChanged="SecretFields_OnPasswordChanged"/>
                </StackPanel>

                <StackPanel x:Name="PanelUrl" VerticalAlignment="Top" Margin="0,0,0,8">
                    <TextBlock x:Name="UrlLabel" Text="API URL (선택 — 비우면 기본값)" FontSize="12" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,4"/>
                    <TextBox x:Name="UrlBox" FontSize="14" Padding="8,6" Margin="0,0,0,4"
                             TextChanged="FormInferenceFields_OnTextChanged"/>
                    <TextBlock x:Name="InferenceHint" FontSize="11" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,14,0,0">
            <Button x:Name="CancelButton" Content="취소" MinWidth="96" Height="38" Margin="0,0,10,0" Click="Cancel_OnClick"/>
            <Button Content="저장" MinWidth="96" Height="38" Style="{StaticResource AccentButton}" Click="Save_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
